            "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Document</title>\n  <link rel=\"stylesheet\" href=\"style.css\">\n</head>\n<body>\n  <button class=\"intro-overlay\" id=\"introOverlay\" type=\"button\" aria-label=\"Start decoding\">\n    <span class=\"intro-overlay__text\">вы должны расшифровать запись, нажмите чтобы начать</span>\n  </button>\n  <div class=\"device\">\n    <div class=\"screen\">\n      <canvas class=\"screen-visualizer\" id=\"wave\" aria-label=\"Audio visualizer\"></canvas>\n      <div class=\"screen-bar\">\n        <div class=\"stats\">\n          <span class=\"stat stat-pink\">Frequency: 0.20</span>\n          <span class=\"stat stat-green\">Stability: 0.50</span>\n          <span class=\"stat stat-blue\">Noise Cut: 0.30</span>\n        </div>\n        <div class=\"timer\">SEARCHING</div>\n        <div class=\"screen-controls\">\n          <div class=\"mode-switch\">\n            <span class=\"mode mode-active\">Tune</span>\n            <span class=\"mode mode-idle\">Archive</span>\n          </div>\n          <div class=\"volume\">\n            <span class=\"volume-icon\"></span>\n            <div class=\"volume-track\">\n              <span class=\"volume-fill\"></span>\n            </div>\n          </div>\n        </div>\n      </div>\n      <!-- <div class=\"timeline\">\n        <div class=\"timeline-track\">\n          <span class=\"tick-label\">00:00</span>\n          <span class=\"tick-gap\"></span>\n          <span class=\"tick-label\">00:10</span>\n          <span class=\"tick-gap\"></span>\n          <span class=\"tick-label\">00:20</span>\n          <span class=\"tick-gap\"></span>\n          <span class=\"tick-label\">00:30</span>\n          <span class=\"tick-gap\"></span>\n          <span class=\"tick-label\">00:40</span>\n          <span class=\"tick-gap\"></span>\n          <span class=\"tick-label\">00:50</span>\n          <span class=\"tick-gap\"></span>\n          <span class=\"tick-label\">01:00</span>\n        </div>\n      </div>\n    </div> -->\n\n    <div class=\"controls-row\">\n    \n      <div class=\"knobs\">\n\n        <div\n          class=\"knob knob-pink\"\n          data-knob=\"frequency\"\n          role=\"slider\"\n          aria-label=\"Frequency\"\n          aria-valuemin=\"0\"\n          aria-valuemax=\"1\"\n          aria-valuenow=\"0.2\"\n          >\n          <div class=\"knob-scale\"></div>\n          <div class=\"knob-ring\">\n            <div class=\"knob-core\">\n              <span class=\"indicator\"></span>\n            </div>\n          </div>\n        </div>\n\n        <div\n          class=\"knob knob-green\"\n          data-knob=\"stability\"\n          role=\"slider\"\n          aria-label=\"Stability\"\n          aria-valuemin=\"0\"\n          aria-valuemax=\"1\"\n          aria-valuenow=\"0.5\"\n          >\n          <div class=\"knob-scale\"></div>\n          <div class=\"knob-ring\">\n            <div class=\"knob-core\">\n              <span class=\"indicator\"></span>\n            </div>\n          </div>\n        </div>\n\n        <div\n          class=\"knob knob-blue\"\n          data-knob=\"noise\"\n          role=\"slider\"\n          aria-label=\"Noise Reduction\"\n          aria-valuemin=\"0\"\n          aria-valuemax=\"1\"\n          aria-valuenow=\"0.3\"\n          >\n          <div class=\"knob-scale\"></div>\n          <div class=\"knob-ring\">\n            <div class=\"knob-core\">\n              <span class=\"indicator\"></span>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"buttons\">\n        <div class=\"button tab\" id=\"tabBtn\" data-button=\"tab\">tab</div>\n        <div class=\"button shift\" data-button=\"shift\">shift</div>\n        <div class=\"button space\" id=\"spaceBtn\" data-button=\"space\">space</div>\n      </div>\n    </div>\n\n    <div class=\"audio-visual\"></div>\n\n    <script type=\"module\" src=\"./scripts/script.js\"></script>\n  </div>\n</body>\n</html>\n"
